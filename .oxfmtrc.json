{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 120,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "tabWidth": 4,
    "ignorePatterns": [
        "node_modules/**",
        "**/node_modules/**",
        ".pnp",
        "**/.pnp",
        ".pnp.*",
        "**/.pnp.*",
        ".yarn/**",
        "**/.yarn/**",
        "coverage/**",
        "**/coverage/**",
        "dist/**",
        "**/dist/**",
        "build/**",
        "**/build/**",
        "*.tsbuildinfo",
        "**/*.tsbuildinfo",
        "pnpm-lock.yaml"
    ]
}
